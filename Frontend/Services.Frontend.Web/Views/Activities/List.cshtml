@model List<Services.Frontend.Web.Services.DTOs.LookupService.ActivitiesDto>

<div class="admin-services-container">
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-primary">Activities Management</h3>
        </div>
        <div class="col-md-6 text-end">
            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addActivityModal">
                <i class="fas fa-plus"></i> Add Activity
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name (AR)</th>
                    <th>Name (EN)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="activitiesTable">
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var activity in Model)
                    {
                        <tr>
                            <td>@activity.Id</td>
                            <td>@activity.NameAr</td>
                            <td>@activity.NameEn</td>
                            <td>
                                <button class="btn btn-sm btn-primary" data-action="edit" data-id="@activity.Id">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-danger" data-action="delete" data-id="@activity.Id">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No activities found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
