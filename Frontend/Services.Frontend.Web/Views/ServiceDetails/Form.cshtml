@model Services.Frontend.Web.Services.DTOs.ManageServices.CreateOrUpdateServiceDetailsDto

<form id="itemForm">
    @if (!string.IsNullOrEmpty(Model?.Id))
    {
        <input type="hidden" asp-for="Id" />
    }

    <!-- Nav tabs -->
    <ul class="nav nav-tabs mb-3" id="serviceDetailsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="structure-tab" data-bs-toggle="tab" data-bs-target="#structure" type="button" role="tab" aria-controls="structure" aria-selected="true">
                <i class="fas fa-sitemap"></i> Service Structure
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="baseinfo-tab" data-bs-toggle="tab" data-bs-target="#baseinfo" type="button" role="tab" aria-controls="baseinfo" aria-selected="false">
                <i class="fas fa-info-circle"></i> Base Info
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="lookups-tab" data-bs-toggle="tab" data-bs-target="#lookups" type="button" role="tab" aria-controls="lookups" aria-selected="false">
                <i class="fas fa-tags"></i> Lookups
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="headers-tab" data-bs-toggle="tab" data-bs-target="#headers" type="button" role="tab" aria-controls="headers" aria-selected="false">
                <i class="fas fa-heading"></i> Headers
            </button>
        </li>
    </ul>

    <!-- Tab content -->
    <div class="tab-content" id="serviceDetailsTabContent">
        <!-- Tab 1: Service Structure -->
        <div class="tab-pane fade show active" id="structure" role="tabpanel" aria-labelledby="structure-tab">
            <input type="hidden" asp-for="MainServiceId" id="MainServiceId" />
            <input type="hidden" asp-for="SubServiceId" id="SubServiceId" />
            <input type="hidden" asp-for="SubSubServiceId" id="SubSubServiceId" />

            <!-- Main Service -->
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-layer-group me-1 text-primary"></i> Main Service
                </label>
                <select class="form-select" id="mainServiceSelect">
                    <option value="">-- Select Main Service --</option>
                    @if (Model?.AllMainServices != null)
                    {
                        @foreach (var ms in Model.AllMainServices)
                        {
                            <option value="@ms.Id"
                                    data-name-ar="@ms.NameAr"
                                    data-name-en="@ms.NameEn"
                                    selected="@(Model.MainServiceId == ms.Id)">@ms.NameAr — @ms.NameEn</option>
                        }
                    }
                </select>
            </div>

            <!-- Sub Service -->
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-code-branch me-1 text-success"></i> Sub Service
                </label>
                <select class="form-select" id="subServiceSelect" disabled>
                    <option value="">-- Select Sub Service --</option>
                    @if (Model?.AllSubServices != null)
                    {
                        @foreach (var ss in Model.AllSubServices)
                        {
                            <option value="@ss.Id"
                                    data-main-service-id="@ss.MainServiceId"
                                    data-name-ar="@ss.NameAr"
                                    data-name-en="@ss.NameEn"
                                    selected="@(Model.SubServiceId == ss.Id)">@ss.NameAr — @ss.NameEn</option>
                        }
                    }
                </select>
            </div>

            <!-- Sub Sub Service -->
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-project-diagram me-1 text-warning"></i> Sub Sub Service
                </label>
                <select class="form-select" id="subSubServiceSelect" disabled>
                    <option value="">-- Select Sub Sub Service --</option>
                    @if (Model?.AllSubSubServices != null)
                    {
                        @foreach (var sss in Model.AllSubSubServices)
                        {
                            <option value="@sss.Id"
                                    data-sub-service-id="@sss.SubServiceId"
                                    data-name-ar="@sss.NameAr"
                                    data-name-en="@sss.NameEn"
                                    selected="@(Model.SubSubServiceId == sss.Id)">@sss.NameAr — @sss.NameEn</option>
                        }
                    }
                </select>
            </div>
        </div>

        <!-- Tab 2: Base Info -->
        <div class="tab-pane fade" id="baseinfo" role="tabpanel" aria-labelledby="baseinfo-tab">
            <div class="mb-3">
                <label class="form-label" asp-for="NameAr">Name (Arabic) <span class="text-danger">*</span></label>
                <input type="text" class="form-control" asp-for="NameAr" required />
                <span asp-validation-for="NameAr" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="NameEn">Name (English) <span class="text-danger">*</span></label>
                <input type="text" class="form-control" asp-for="NameEn" required />
                <span asp-validation-for="NameEn" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="DescriptionAr">Description (Arabic)</label>
                <textarea class="form-control" asp-for="DescriptionAr" rows="3"></textarea>
                <span asp-validation-for="DescriptionAr" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="DescriptionEn">Description (English)</label>
                <textarea class="form-control" asp-for="DescriptionEn" rows="3"></textarea>
                <span asp-validation-for="DescriptionEn" class="text-danger"></span>
            </div>
        </div>

        <!-- Tab 3: Lookups -->
        <div class="tab-pane fade" id="lookups" role="tabpanel" aria-labelledby="lookups-tab">

            <!-- Row 1: Activities + Domains -->
            <div class="row g-3 mb-3">

                <!-- Activities Selection -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-running me-1 text-primary"></i> Activities
                        <span class="badge bg-primary ms-1" id="actCount">0</span>
                    </label>
                    <div class="border rounded" style="height: 270px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width:30px"></th>
                                    <th>Arabic</th>
                                    <th>English</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.AllActivities)
                                {
                                    <tr class="lookup-row">
                                        <td>
                                            <input class="form-check-input lookup-chk"
                                                   type="checkbox"
                                                   name="Activities"
                                                   value="@item.Id"
                                                   id="act_@item.Id"
                                                   checked="@(Model.Activities != null && Model.Activities.Contains(item.Id))" />
                                        </td>
                                        <td><label class="mb-0 w-100" for="act_@item.Id">@item.NameAr</label></td>
                                        <td><label class="mb-0 w-100" for="act_@item.Id">@item.NameEn</label></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Domains Selection -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-globe me-1 text-success"></i> Domains
                        <span class="badge bg-success ms-1" id="domCount">0</span>
                    </label>
                    <div class="border rounded" style="height: 270px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width:30px"></th>
                                    <th>Arabic</th>
                                    <th>English</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.AllDomains)
                                {
                                    <tr class="lookup-row">
                                        <td>
                                            <input class="form-check-input lookup-chk"
                                                   type="checkbox"
                                                   name="Domains"
                                                   value="@item.Id"
                                                   id="dom_@item.Id"
                                                   checked="@(Model.Domains != null && Model.Domains.Contains(item.Id))" />
                                        </td>
                                        <td><label class="mb-0 w-100" for="dom_@item.Id">@item.NameAr</label></td>
                                        <td><label class="mb-0 w-100" for="dom_@item.Id">@item.NameEn</label></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <!-- Row 2: Tags -->
            <div class="row g-3">

                <!-- Tags Selection -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-tags me-1 text-warning"></i> Tags
                        <span class="badge bg-warning text-dark ms-1" id="tagCount">0</span>
                    </label>
                    <div class="border rounded" style="height: 270px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width:30px"></th>
                                    <th>Arabic</th>
                                    <th>English</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.AllTags)
                                {
                                    <tr class="lookup-row">
                                        <td>
                                            <input class="form-check-input lookup-chk"
                                                   type="checkbox"
                                                   name="Tags"
                                                   value="@item.Id"
                                                   id="tag_@item.Id"
                                                   checked="@(Model.Tags != null && Model.Tags.Contains(item.Id))" />
                                        </td>
                                        <td><label class="mb-0 w-100" for="tag_@item.Id">@item.NameAr</label></td>
                                        <td><label class="mb-0 w-100" for="tag_@item.Id">@item.NameEn</label></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
        <!-- Tab 4: Headers -->
        <div class="tab-pane fade" id="headers" role="tabpanel" aria-labelledby="headers-tab">
            <div class="row g-3">

                <!-- Left: Available Headers List -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-heading me-1 text-secondary"></i> Available Headers
                    </label>
                    <div class="border rounded" style="height: 350px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Arabic</th>
                                    <th>English</th>
                                </tr>
                            </thead>
                            <tbody id="headersList">
                                @if (Model?.AllHeaders != null && Model.AllHeaders.Count > 0)
                                {
                                    @foreach (var header in Model.AllHeaders)
                                    {
                                        <tr class="header-select-row"
                                            data-id="@header.Id"
                                            data-name-ar="@header.NameAr"
                                            data-name-en="@header.NameEn"
                                            style="cursor:pointer;">
                                            <td>@header.NameAr</td>
                                            <td>@header.NameEn</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="2" class="text-center text-muted">No headers available</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Right: Value Input + Added Headers Table -->
                <div class="col-md-6">

                    <!-- Value input card (shown on row selection) -->
                    <div id="headerValueForm" class="card border-primary p-3 mb-3 d-none">
                        <h6 class="text-primary mb-3">
                            <i class="fas fa-edit me-1"></i>
                            <span id="selectedHeaderName"></span>
                        </h6>
                        <div class="row g-2">
                            <div class="col-12">
                                <label class="form-label form-label-sm" for="headerValueAr">Value (Arabic)</label>
                                <input type="text" class="form-control form-control-sm" id="headerValueAr" placeholder="Arabic value..." />
                            </div>
                            <div class="col-12">
                                <label class="form-label form-label-sm" for="headerValueEn">Value (English)</label>
                                <input type="text" class="form-control form-control-sm" id="headerValueEn" placeholder="English value..." />
                            </div>
                        </div>
                        <div class="mt-3 d-flex gap-2">
                            <button type="button" class="btn btn-success btn-sm" id="addBtn">
                                <i class="fas fa-plus me-1"></i> Add
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="cancelHeaderBtn">
                                Cancel
                            </button>
                        </div>
                    </div>

                    

                </div>

                <!-- Added headers table -->
                <div class="col-md-12" id="headersResultTable" style="display:none;">
                    <table class="table table-bordered table-striped table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Header</th>
                                <th>Value (Ar)</th>
                                <th>Value (En)</th>
                                <th width="100">Actions</th>
                            </tr>
                        </thead>
                                        <tbody id="dataTableBody"></tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>

                        <script id="existingHeadersJson" type="application/json">
                            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.HeadersValue ?? new List<Services.Frontend.Web.Services.DTOs.ManageServices.HeaderValueDto>(),
                                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
                        </script>

