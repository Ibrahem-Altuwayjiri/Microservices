@model List<Services.Frontend.Web.Services.DTOs.ManageServices.ServiceDetailsDto>

<div class="admin-services-container">
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-primary">Service Details Management</h3>
        </div>
        <div class="col-md-6 text-end">
            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#formModal" onclick="openForm('ServiceDetails')">
                <i class="fas fa-plus"></i> Add Service Details
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name (AR)</th>
                    <th>Name (EN)</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="serviceDetailsTable">
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var service in Model)
                    {
                        <tr>
                            <td>@service.Id</td>
                            <td>@service.NameAr</td>
                            <td>@service.NameEn</td>
                            <td>
                                <span class="badge @(service.IsActive ? "bg-success" : "bg-secondary")">
                                    @(service.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-info" data-action="view" data-id="@service.Id">
                                    <i class="fas fa-eye"></i> View
                                </button>
                                <button class="btn btn-sm btn-primary" data-action="edit" data-id="@service.Id">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-danger" data-action="delete" data-id="@service.Id">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No service details found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
