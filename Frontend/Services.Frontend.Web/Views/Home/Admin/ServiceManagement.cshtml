@{
    ViewData["Title"] = "Service Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/service-management.css" />

<div class="service-management-container">
    <!-- Page Header -->
    <div class="page-header mb-5">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="page-title">
                    <i class="fas fa-cog"></i> Service Management
                </h1>
                <p class="page-subtitle">Manage all services, activities, and configurations</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="sort-filter-group">
                    <button class="btn btn-outline-primary btn-sm me-2" id="sortBtn">
                        <i class="fas fa-sort"></i> Sort
                    </button>
                    <select class="form-select form-select-sm d-inline-block" style="width: auto;" id="filterSelect">
                        <option value="">All Services</option>
                        <option value="structure">Service Structure</option>
                        <option value="lookups">Lookups</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Service Cards Grid -->
    <div class="services-cards-grid">
        <div class="row g-4">
            <!-- Services Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="MainServices">
                    <div class="card-icon-container">
                        <i class="fas fa-briefcase"></i>
                    </div>
                    <h5 class="card-title">Services</h5>
                    <p class="card-description">Manage and organize main services and their details</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('MainServices')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('MainServices')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>

            <!-- Activities Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="Activities">
                    <div class="card-icon-container">
                        <i class="fas fa-tasks"></i>
                    </div>
                    <h5 class="card-title">Activities</h5>
                    <p class="card-description">Manage service activities and classifications</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('Activities')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('Activities')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>

            <!-- Domains Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="Domains">
                    <div class="card-icon-container">
                        <i class="fas fa-globe"></i>
                    </div>
                    <h5 class="card-title">Domains</h5>
                    <p class="card-description">Manage service domains and categories</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('Domains')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('Domains')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>

            <!-- Tags Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="Tags">
                    <div class="card-icon-container">
                        <i class="fas fa-tags"></i>
                    </div>
                    <h5 class="card-title">Tags</h5>
                    <p class="card-description">Manage service tags and keywords</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('Tags')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('Tags')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>

            <!-- Headers Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="Headers">
                    <div class="card-icon-container">
                        <i class="fas fa-heading"></i>
                    </div>
                    <h5 class="card-title">Headers</h5>
                    <p class="card-description">Manage service header configurations</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('Headers')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('Headers')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sub Services Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="SubServices">
                    <div class="card-icon-container">
                        <i class="fas fa-stream"></i>
                    </div>
                    <h5 class="card-title">Sub Services</h5>
                    <p class="card-description">Manage service hierarchy and structure</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('SubServices')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('SubServices')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sub-Sub Services Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="SubSubServices">
                    <div class="card-icon-container">
                        <i class="fas fa-sitemap"></i>
                    </div>
                    <h5 class="card-title">Sub-Sub Services</h5>
                    <p class="card-description">Manage detailed service categorization and classification</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('SubSubServices')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('SubSubServices')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>

            <!-- Service Details Card -->
            <div class="col-md-6 col-lg-4">
                <div class="service-management-card" data-service="ServiceDetails">
                    <div class="card-icon-container">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <h5 class="card-title">Service Details</h5>
                    <p class="card-description">Manage detailed service information and metadata</p>
                    <div class="card-actions">
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="openForm('ServiceDetails')">
                            <i class="fas fa-plus"></i> Add New
                        </button>
                        <button class="btn btn-outline-primary btn-sm btn-action" onclick="viewAll('ServiceDetails')">
                            <i class="fas fa-list"></i> View All
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Area for Forms/Tables -->
    <div id="contentArea" class="mt-5"></div>
</div>

<!-- Unified Form Modal -->
<div class="modal fade" id="formModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="formTitle">Add New Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="formContent">
                <!-- Form will be loaded from partial view -->
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveBtn">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Unified View All Modal -->
<div class="modal fade" id="viewAllModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tableTitle">All Items</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="tableContent">
                <!-- Table will be loaded from partial view -->
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this item? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- View Details Modal -->
<div class="modal fade" id="viewDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewDetailsTitle">
                    <i class="fas fa-eye me-2"></i> Service Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="viewDetailsContent">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/service-management.js" asp-append-version="true"></script>
}
